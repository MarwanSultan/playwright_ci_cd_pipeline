{
"annotations": {"list": []},
"description": "Robust Playwright Metrics Dashboard with Individual Test Tracking and 20 Panels",
"editable": true,
"panels": [
{"type": "stat", "title": "Total Tests Run", "gridPos": {"x":0,"y":0,"w":6,"h":4}, "targets":[{"expr":"playwright_tests_run_total","legendFormat":"{{project}} - {{browser}}","refId":"A"}]},
{"type": "stat", "title": "Tests Passed", "gridPos": {"x":6,"y":0,"w":6,"h":4}, "targets":[{"expr":"playwright_tests_passed_total","legendFormat":"{{project}} - {{browser}}","refId":"B"}]},
{"type": "stat", "title": "Tests Failed", "gridPos": {"x":12,"y":0,"w":6,"h":4}, "targets":[{"expr":"playwright_tests_failed_total","legendFormat":"{{project}} - {{browser}}","refId":"C"}]},
{"type": "stat", "title": "Tests Skipped", "gridPos": {"x":0,"y":4,"w":6,"h":4}, "targets":[{"expr":"playwright_tests_skipped_total","legendFormat":"{{project}} - {{browser}}","refId":"D"}]},
{"type": "stat", "title": "Flaky Tests", "gridPos": {"x":6,"y":4,"w":6,"h":4}, "targets":[{"expr":"playwright_tests_flaky_total","legendFormat":"{{project}} - {{browser}}","refId":"E"}]},
{"type": "gauge", "title": "Pass Rate %", "gridPos": {"x":12,"y":4,"w":6,"h":4}, "targets":[{"expr":"playwright_tests_passed_total / playwright_tests_run_total * 100","refId":"F"}]},

```
// Individual Test Panels
{"type":"bar gauge","title":"Test 1 Status","gridPos":{"x":0,"y":8,"w":6,"h":4},"targets":[{"expr":"playwright_tests_run_total{test_name='Test1'}","refId":"G"}]},
{"type":"bar gauge","title":"Test 2 Status","gridPos":{"x":6,"y":8,"w":6,"h":4},"targets":[{"expr":"playwright_tests_run_total{test_name='Test2'}","refId":"H"}]},
{"type": "graph", "title": "Test 1 Duration (seconds)", "gridPos": {"x":0,"y":12,"w":6,"h":4}, "targets":[{"expr":"rate(playwright_test_duration_seconds_sum{test_name='Test1'}[1m]) / rate(playwright_test_duration_seconds_count{test_name='Test1'}[1m])","refId":"I"}]},
{"type": "graph", "title": "Test 2 Duration (seconds)", "gridPos": {"x":6,"y":12,"w":6,"h":4}, "targets":[{"expr":"rate(playwright_test_duration_seconds_sum{test_name='Test2'}[1m]) / rate(playwright_test_duration_seconds_count{test_name='Test2'}[1m])","refId":"J"}]},

{"type": "graph", "title": "Average Test Duration (seconds)", "gridPos": {"x":0,"y":16,"w":12,"h":6}, "targets":[{"expr":"rate(playwright_test_duration_seconds_sum[1m]) / rate(playwright_test_duration_seconds_count[1m])","legendFormat":"{{project}} - {{browser}}","refId":"K"}]},
{"type": "heatmap", "title": "Test Duration Histogram", "gridPos": {"x":12,"y":16,"w":12,"h":6}, "targets":[{"expr":"playwright_test_duration_seconds_bucket","legendFormat":"{{le}} sec","refId":"L"}]},
{"type": "graph", "title": "Failed Tests Trend", "gridPos": {"x":0,"y":22,"w":12,"h":6}, "targets":[{"expr":"increase(playwright_tests_failed_total[1h])","legendFormat":"Failed Tests","refId":"M"}]},
{"type": "graph", "title": "Pass Rate Trend", "gridPos": {"x":12,"y":22,"w":12,"h":6}, "targets":[{"expr":"playwright_tests_passed_total / playwright_tests_run_total * 100","legendFormat":"Pass Rate %","refId":"N"}]},

{"type": "bar chart", "title": "Browser Pass Rate", "gridPos": {"x":0,"y":28,"w":12,"h":6}, "targets":[{"expr":"playwright_tests_passed_total / playwright_tests_run_total * 100","legendFormat":"{{browser}}","refId":"O"}]},
{"type": "bar chart", "title": "Project Pass Rate", "gridPos": {"x":12,"y":28,"w":12,"h":6}, "targets":[{"expr":"playwright_tests_passed_total / playwright_tests_run_total * 100","legendFormat":"{{project}}","refId":"P"}]},
{"type": "table", "title": "Slowest Tests", "gridPos": {"x":0,"y":34,"w":12,"h":6}, "targets":[{"expr":"topk(10, max_over_time(playwright_test_duration_seconds[1h]))","refId":"Q"}]},
{"type": "table", "title": "Duration Distribution Table", "gridPos": {"x":12,"y":34,"w":12,"h":6}, "targets":[{"expr":"playwright_test_duration_seconds_bucket","refId":"R"}]}
```

