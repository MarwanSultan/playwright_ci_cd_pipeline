{
  "annotations": {"list": []},
  "description": "Comprehensive Playwright Test Metrics Dashboard",
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Total Tests Run",
      "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "targets":[{"expr":"playwright_tests_run_total","legendFormat":"{{project}} - {{browser}}","refId":"A"}]
    },
    {
      "type": "stat",
      "title": "Tests Passed",
      "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "targets":[{"expr":"playwright_tests_passed_total","legendFormat":"{{project}} - {{browser}}","refId":"A"}]
    },
    {
      "type": "stat",
      "title": "Tests Failed",
      "gridPos": {"x":12,"y":0,"w":6,"h":4},
      "targets":[{"expr":"playwright_tests_failed_total","legendFormat":"{{project}} - {{browser}}","refId":"A"}]
    },
    {
      "type": "stat",
      "title": "Tests Skipped",
      "gridPos": {"x":0,"y":4,"w":6,"h":4},
      "targets":[{"expr":"playwright_tests_skipped_total","legendFormat":"{{project}} - {{browser}}","refId":"B"}]
    },
    {
      "type": "stat",
      "title": "Flaky Tests",
      "gridPos": {"x":6,"y":4,"w":6,"h":4},
      "targets":[{"expr":"playwright_tests_flaky_total","legendFormat":"{{project}} - {{browser}}","refId":"C"}]
    },
    {
      "type": "gauge",
      "title": "Pass Rate %",
      "gridPos": {"x":12,"y":4,"w":6,"h":4},
      "targets":[{"expr":"playwright_tests_passed_total / playwright_tests_run_total * 100","refId":"D"}]
    },
    {
      "type": "graph",
      "title": "Average Test Duration (seconds)",
      "gridPos": {"x":0,"y":8,"w":12,"h":6},
      "targets":[{"expr":"rate(playwright_test_duration_seconds_sum[1m]) / rate(playwright_test_duration_seconds_count[1m])","legendFormat":"{{project}} - {{browser}}","refId":"E"}]
    },
    {
      "type": "heatmap",
      "title": "Test Duration Histogram",
      "gridPos": {"x":12,"y":8,"w":12,"h":6},
      "targets":[{"expr":"playwright_test_duration_seconds_bucket","legendFormat":"{{le}} sec","refId":"F"}]
    },
    {
      "type": "graph",
      "title": "Failed Tests Trend",
      "gridPos": {"x":0,"y":14,"w":12,"h":6},
      "targets":[{"expr":"increase(playwright_tests_failed_total[1h])","legendFormat":"Failed Tests","refId":"G"}]
    }
  ],
  "templating": {
    "list": [
      {"name":"project","type":"query","label":"Project","query":"label_values(playwright_tests_run_total, project)","multi":true,"includeAll":true},
      {"name":"browser","type":"query","label":"Browser","query":"label_values(playwright_tests_run_total, browser)","multi":true,"includeAll":true},
      {"name":"build","type":"query","label":"Build","query":"label_values(playwright_tests_run_total, build)","multi":true,"includeAll":true}
    ]
  },
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["playwright","tests","metrics"],
  "time": {"from":"now-1h","to":"now"},
  "title": "Comprehensive Playwright Test Metrics",
  "version": 2
}
